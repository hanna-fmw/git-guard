#!/bin/bash
# Global pre-commit hook — two checks, both bypassable with --no-verify.
#
#   CHECK 1: blocks staged FILE PATHS matching ~/.git-hooks/blocked-paths
#            (whatever you've decided to never commit – e.g. .claude/, private/, NOTES.md)
#   CHECK 2: blocks staged CONTENT matching ~/.git-hooks/sensitive-patterns
#            (your name, emails, phone numbers, etc. in added lines)
#
# Override one commit:  git commit --no-verify
# Skip in one repo:     git config hooks.skipSensitiveCheck true
# Tune file blocks:     edit ~/.git-hooks/blocked-paths
# Tune content scan:    edit ~/.git-hooks/sensitive-patterns

set -u
PATTERNS_FILE="${GIT_HOOKS_PATTERNS:-$HOME/.git-hooks/sensitive-patterns}"
BLOCKED_PATHS_FILE="${GIT_HOOKS_BLOCKED_PATHS:-$HOME/.git-hooks/blocked-paths}"
ALLOWLIST_FILE="${GIT_HOOKS_ALLOWLIST:-$HOME/.git-hooks/content-allowlist}"

if [ "$(git config --bool hooks.skipSensitiveCheck 2>/dev/null)" = "true" ]; then
    exit 0
fi

# ─────────────────────────────────────────────────────────────────────
# CHECK 1 — blocked file paths
# ─────────────────────────────────────────────────────────────────────
if [ -f "$BLOCKED_PATHS_FILE" ]; then
    BLOCKED_ACTIVE=$(mktemp)
    BLOCKED_HITS=$(mktemp)
    trap 'rm -f "$BLOCKED_ACTIVE" "$BLOCKED_HITS"' EXIT

    grep -vE '^[[:space:]]*(#|$)' "$BLOCKED_PATHS_FILE" > "$BLOCKED_ACTIVE"

    if [ -s "$BLOCKED_ACTIVE" ]; then
        # Only flag ADDED/MODIFIED files. Deletions of blocked paths are
        # hygiene (we WANT those tracked files gone), so don't block them.
        STAGED=$(git diff --cached --name-only --diff-filter=AM 2>/dev/null)
        if [ -n "$STAGED" ]; then
            printf '%s\n' "$STAGED" | grep -E -f "$BLOCKED_ACTIVE" > "$BLOCKED_HITS" || true
        fi

        if [ -s "$BLOCKED_HITS" ]; then
            # Cut through scroll noise — sound + interactive dialog.
            afplay /System/Library/Sounds/Sosumi.aiff >/dev/null 2>&1 &
            HIT_FILES=$(cat "$BLOCKED_HITS")
            HIT_LIST_ESC=$(echo "$HIT_FILES" | sed 's/"/\\"/g')
            ACTION=$(osascript <<APPLESCRIPT 2>/dev/null
set hitList to "$HIT_LIST_ESC"
set theButtons to {"Cancel", "Open in editor", "Commit anyway"}
display dialog "Pre-commit is about to ship these files which are on the never-commit list:" & return & return & hitList & return & return & "If you intentionally want to commit one of these — click Commit anyway." & return & return & "To unstage and inspect — click Open in editor." & return & return & "Cancel = keep blocked. Nothing ships." with title "Git pre-commit" buttons theButtons default button "Cancel" cancel button "Cancel" with icon caution
return button returned of result
APPLESCRIPT
)
            if [ "$ACTION" = "Commit anyway" ]; then
                echo "→ Approved in dialog. Proceeding with commit." >&2
                exit 0
            fi
            if [ "$ACTION" = "Open in editor" ]; then
                while IFS= read -r f; do
                    [ -n "$f" ] && command -v code >/dev/null 2>&1 && code "$f" 2>/dev/null
                done <<< "$HIT_FILES"
            fi
            echo ""
            echo "═══════════════════════════════════════════════════════════════════"
            echo "  ⛔  Pre-commit hook blocked staged files"
            echo "═══════════════════════════════════════════════════════════════════"
            echo ""
            echo "These staged paths match the never-commit list:"
            echo ""
            sed 's/^/  /' "$BLOCKED_HITS"
            echo ""
            echo "───────────────────────────────────────────────────────────────────"
            echo "Nothing was committed. Commit is blocked until you decide:"
            echo ""
            echo "  1. KEEP IT BLOCKED — do nothing. The files stay in your working"
            echo "     tree, nothing is committed, nothing is pushed."
            echo "     (Safe default. Walk away and nothing leaks.)"
            echo ""
            echo "  2. UNSTAGE THEM — keep the files locally, just don't commit:"
            echo ""
            echo "         git restore --staged <file>"
            echo ""
            echo "     If a file was previously tracked and you want it ignored from"
            echo "     now on, also run:"
            echo ""
            echo "         git rm --cached <file>"
            echo ""
            echo "     Then re-stage what you do want and commit again."
            echo ""
            echo "  3. ACCEPT IT — if you intentionally want to commit one of these"
            echo "     (rare; the global gitignore already prevents accidents):"
            echo ""
            echo "         git commit --no-verify"
            echo ""
            echo "  Tune blocked paths:  $BLOCKED_PATHS_FILE"
            echo "  Skip in one repo:    git config hooks.skipSensitiveCheck true"
            echo "═══════════════════════════════════════════════════════════════════"
            exit 1
        fi
    fi
fi

# ─────────────────────────────────────────────────────────────────────
# CHECK 2 — sensitive content in added lines
# ─────────────────────────────────────────────────────────────────────
if [ ! -f "$PATTERNS_FILE" ]; then
    exit 0
fi

ACTIVE=$(mktemp)
DIFF=$(mktemp)
RESULTS=$(mktemp)
cleanup() { rm -f "$ACTIVE" "$DIFF" "$RESULTS"; }
trap cleanup EXIT

grep -vE '^[[:space:]]*(#|$)' "$PATTERNS_FILE" > "$ACTIVE"
if [ ! -s "$ACTIVE" ]; then
    exit 0
fi

# Optional allowlist of file paths where the content scan is skipped.
# Useful for LICENSE / NOTICE / AUTHORS where your name is supposed to appear.
ALLOWLIST_ACTIVE=$(mktemp)
if [ -f "$ALLOWLIST_FILE" ]; then
    grep -vE '^[[:space:]]*(#|$)' "$ALLOWLIST_FILE" > "$ALLOWLIST_ACTIVE"
fi
trap 'rm -f "$ACTIVE" "$DIFF" "$RESULTS" "$ALLOWLIST_ACTIVE"' EXIT

if ! git diff --cached --unified=0 --no-color > "$DIFF" 2>/dev/null; then
    echo "pre-commit hook: failed to read staged diff — blocking to be safe." >&2
    exit 1
fi

current_file=""
current_line=0
file_allowed=0

while IFS= read -r line; do
    case "$line" in
        "+++ b/"*)
            current_file="${line#+++ b/}"
            file_allowed=0
            if [ -s "$ALLOWLIST_ACTIVE" ] && printf '%s\n' "$current_file" | grep -qE -f "$ALLOWLIST_ACTIVE"; then
                file_allowed=1
            fi
            ;;
        "+++"*)
            ;;
        "@@"*)
            hunk="${line#*+}"
            hunk="${hunk%% *}"
            current_line="${hunk%%,*}"
            ;;
        "+"*)
            if [ "$file_allowed" = "1" ]; then
                current_line=$((current_line + 1))
                continue
            fi
            added="${line:1}"
            match=$(printf '%s\n' "$added" | grep -Eo -f "$ACTIVE" 2>/dev/null | head -1)
            if [ -n "$match" ]; then
                printf '  %s:%d  → %s\n' "$current_file" "$current_line" "$match" >> "$RESULTS"
            fi
            current_line=$((current_line + 1))
            ;;
    esac
done < "$DIFF"

if [ -s "$RESULTS" ]; then
    afplay /System/Library/Sounds/Sosumi.aiff >/dev/null 2>&1 &
    # Show every flagged hit in the dialog (file:line and the matched text),
    # so the user can decide without leaving the dialog.
    HIT_PREVIEW=$(sed 's/^[[:space:]]*//' "$RESULTS" | head -10 | sed 's/"/\\"/g')
    # Parsable "file:line" list for the "Open in editor" jump action.
    HIT_FILELINES=$(sed -E 's/^[[:space:]]*([^:]+):([0-9]+).*/\1:\2/' "$RESULTS" | sort -u)
    ACTION=$(osascript <<APPLESCRIPT 2>/dev/null
set hitList to "$HIT_PREVIEW"
set theButtons to {"Cancel", "Open in editor", "Commit anyway"}
display dialog "Pre-commit flagged these matches in the diff you're about to commit:" & return & return & hitList & return & return & "If this is intentional (e.g. your own name in LICENSE / copyright, your support email in a help page) — click Commit anyway." & return & return & "If you need to scrub it — click Open in editor (jumps to the exact line)." & return & return & "Cancel = keep blocked. Nothing ships." with title "Git pre-commit" buttons theButtons default button "Cancel" cancel button "Cancel" with icon caution
return button returned of result
APPLESCRIPT
)
    if [ "$ACTION" = "Commit anyway" ]; then
        echo "→ Approved in dialog. Proceeding with commit." >&2
        exit 0
    fi
    if [ "$ACTION" = "Open in editor" ]; then
        # `code --goto file:line` opens VS Code at the exact line.
        while IFS= read -r fl; do
            [ -n "$fl" ] && command -v code >/dev/null 2>&1 && code --goto "$fl" 2>/dev/null
        done <<< "$HIT_FILELINES"
    fi
    echo ""
    echo "═══════════════════════════════════════════════════════════════════"
    echo "  ⚠  Pre-commit hook flagged potentially sensitive content"
    echo "═══════════════════════════════════════════════════════════════════"
    echo ""
    cat "$RESULTS"
    echo ""
    echo "───────────────────────────────────────────────────────────────────"
    echo "Nothing was committed. Commit is blocked until you decide:"
    echo ""
    echo "  1. KEEP IT BLOCKED — do nothing. The flagged content stays in"
    echo "     your working tree, nothing is committed, nothing is pushed."
    echo "     (This is the safe default. Walk away and the AI cannot push.)"
    echo ""
    echo "  2. SCRUB IT — edit the file(s), replace with a generic value"
    echo "     (e.g. test@example.com, ~/Desktop/), re-stage, commit again."
    echo ""
    echo "  3. ACCEPT IT — if the match is intentional (your portfolio name,"
    echo "     a product support email, a test fixture), commit anyway:"
    echo ""
    echo "         git commit --no-verify"
    echo ""
    echo "  Tune patterns:     $PATTERNS_FILE"
    echo "  Skip in one repo:  git config hooks.skipSensitiveCheck true"
    echo "═══════════════════════════════════════════════════════════════════"
    exit 1
fi

exit 0
